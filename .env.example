# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Admin auth ────────────────────────────────────────────────────────────────
# Choose a strong password for the /admin panel
ADMIN_PASSWORD="changeme"

# ── Timezone ──────────────────────────────────────────────────────────────────
# Used for generating time slots and formatting emails.
# Any valid IANA timezone string (e.g. America/New_York, Europe/London, Asia/Singapore)
TIMEZONE="America/New_York"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Email shown in the "From:" field
FROM_EMAIL="Nail Studio <your-email@gmail.com>"

# Email that receives booking notifications
ADMIN_EMAIL="your-email@gmail.com"
